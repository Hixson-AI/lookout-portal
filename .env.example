# Lookout Portal - Local Development Environment Variables

# Control Plane (lookout-control) Configuration
VITE_CONTROL_PLANE_URL=http://localhost:9443

# API Plane (lookout-api) Configuration
VITE_API_BASE_URL=http://localhost:9444

# Google OAuth (for local development)
# Create a Google OAuth 2.0 client ID for localhost:7333
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Environment
NODE_ENV=development
